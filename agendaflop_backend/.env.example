# =============================================================================
# AGENDAFLOP - VARIABLES DE ENTORNO
# =============================================================================
# Este archivo es un TEMPLATE. Copia este archivo como .env y personaliza
# los valores según tu entorno.
#
# IMPORTANTE: .env NO debe estar en Git (ya está en .gitignore)
# =============================================================================

# =============================================================================
# DJANGO CORE
# =============================================================================

# SECRET_KEY: Clave secreta de Django (genera una nueva para producción)
# Puedes generarla con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-CAMBIA-ESTO-POR-UNA-CLAVE-SEGURA-EN-PRODUCCION

# DEBUG: Modo de depuración (True solo en desarrollo, False en producción)
DEBUG=True

# ALLOWED_HOSTS: Hosts/dominios permitidos (separados por comas)
# Ejemplo producción: ALLOWED_HOSTS=agendaflop.com,www.agendaflop.com,api.agendaflop.com
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# BASE DE DATOS - MySQL/MariaDB
# =============================================================================

# Configuración de la base de datos principal
DB_ENGINE=django.db.backends.mysql
DB_NAME=agendaflop
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_HOST=localhost
DB_PORT=3306

# Opciones adicionales de MySQL (opcional)
DB_OPTIONS_INIT_COMMAND=SET sql_mode='STRICT_TRANS_TABLES'

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
# Habilitar CORS para permitir requests desde frontend en otro dominio

# CORS_ALLOWED_ORIGINS: Dominios permitidos (separados por comas)
# Desarrollo: http://localhost:3000,http://localhost:5173
# Producción: https://app.agendaflop.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# CORS_ALLOW_ALL_ORIGINS: Permitir todos los orígenes (solo desarrollo)
CORS_ALLOW_ALL_ORIGINS=False

# =============================================================================
# EMAIL (para notificaciones)
# =============================================================================

# Configuración de email (Gmail, SendGrid, AWS SES, etc.)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_email@gmail.com
EMAIL_HOST_PASSWORD=tu_password_de_aplicacion
DEFAULT_FROM_EMAIL=AgendaFlop <noreply@agendaflop.com>

# =============================================================================
# REDIS (para cache y Celery)
# =============================================================================

# REDIS_URL: URL de conexión a Redis
# Desarrollo local: redis://localhost:6379/0
# Producción: redis://:password@host:6379/0
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# CELERY (tareas asíncronas)
# =============================================================================

# CELERY_BROKER_URL: Broker de mensajes (Redis o RabbitMQ)
CELERY_BROKER_URL=redis://localhost:6379/0

# CELERY_RESULT_BACKEND: Almacenamiento de resultados
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# ALMACENAMIENTO (AWS S3, Azure Storage, etc.)
# =============================================================================

# USE_S3: Usar S3 para archivos estáticos/media
USE_S3=False

# AWS_ACCESS_KEY_ID: Credenciales de AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# =============================================================================
# PAGOS (Stripe, PayPal, MercadoPago, etc.)
# =============================================================================

# STRIPE_PUBLIC_KEY: Clave pública de Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# SMS/WhatsApp (Twilio, etc.)
# =============================================================================

# TWILIO_ACCOUNT_SID: Credenciales de Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =============================================================================
# SENTRY (Monitoreo de errores)
# =============================================================================

# SENTRY_DSN: URL de Sentry para tracking de errores en producción
SENTRY_DSN=

# =============================================================================
# VARIABLES ADICIONALES
# =============================================================================

# ENVIRONMENT: Entorno actual (development, staging, production)
ENVIRONMENT=development

# LOG_LEVEL: Nivel de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
