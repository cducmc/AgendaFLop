# Django
SECRET_KEY=change-me-in-production
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.prod
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO
ENABLE_HTTPS=False

# CORS/CSRF
CORS_ALLOWED_ORIGINS=http://localhost
CSRF_TRUSTED_ORIGINS=http://localhost

# PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=agendaflop
DB_USER=agendaflop
DB_PASSWORD=agendaflop_password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Email (set real values in production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@agendaflop.com
